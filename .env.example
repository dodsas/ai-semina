# Turso 데이터베이스 연결 정보 (실제 값은 .env 에 두고 절대 커밋하지 마세요)
TURSO_URL=libsql://<your-db>.turso.io
TURSO_TOKEN=<your-auth-token>

# 관리자 계정 (일정 확정 권한)
ADMIN=<admin-id>
PW=<admin-password>

# 요청 메일 발송용 SMTP (미설정 시 요청은 저장되지만 메일은 발송되지 않음)
# 예) Gmail: SMTP_HOST=smtp.gmail.com / SMTP_PORT=587 / SMTP_USER=계정 / SMTP_PASS=앱비밀번호
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# 발송인 표시 주소 (생략 시 SMTP_USER 사용) — 값은 무엇이든 무방
MAIL_FROM=
