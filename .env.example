# Turso 데이터베이스 연결 정보 (실제 값은 .env 에 두고 절대 커밋하지 마세요)
TURSO_URL=libsql://<your-db>.turso.io
TURSO_TOKEN=<your-auth-token>

# 관리자 계정 (일정 확정 권한)
ADMIN=<admin-id>
PW=<admin-password>

# 요청 메일 발송 (미설정 시 요청은 저장되지만 메일은 발송되지 않음)
# 발송 우선순위: Brevo → Resend → SMTP

# [권장·가장 간단] Brevo(구 Sendinblue) — 도메인 불필요, 발신 이메일 1개만 클릭 인증
#   1) brevo.com 가입 → Senders 에서 보낼 이메일(본인 gmail 등) 추가 → 받은 확인메일 링크 클릭
#   2) SMTP & API → API Keys 발급 → BREVO_API_KEY 에 입력
#   3) MAIL_FROM 을 위에서 인증한 그 이메일로 설정 (HTTP API, 무료 300통/일)
BREVO_API_KEY=
MAIL_FROM=

# [대체1] Resend HTTP API — 도메인 인증 필요(단일 이메일 인증 미지원)
RESEND_API_KEY=

# [대체2] SMTP — PaaS(Render 등)에서 포트가 막히면 타임아웃 날 수 있음
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
